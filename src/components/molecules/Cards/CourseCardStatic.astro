---
// Componente estático de tarjeta de curso para páginas prerenderizadas (SSR/SSG)
// Para páginas con hidratación React (con soporte de moneda), usar CourseCard.tsx

import type { Curso } from '@graphql-astro/generated/graphql';

// Props: recibe las propiedades del curso desde el componente padre
interface Props extends Curso {}

const {
    courseTitle,
    imagenURL,
    descripcionCorta,
    slug,
} = Astro.props;

// Slug por defecto si no se proporciona
const slugCurso = slug || 'curso-no-encontrado';
---

<div class="card bg-[var(--color-surface)] shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 h-full flex flex-col group overflow-hidden border border-base-200">
    <!-- Imagen del curso con enlace -->
    <a href={`/cursos/${slugCurso}`} class="block relative aspect-video overflow-hidden">
        <figure class="w-full h-full">
            <img
                src={imagenURL?.url}
                alt={imagenURL?.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
        </figure>
    </a>

    <div class="card-body p-5 flex flex-col flex-grow gap-2">
        <!-- Título y descripción del curso -->
        <a href={`/cursos/${slugCurso}`} class="hover:text-[var(--color-primary)] transition-colors">
            <h2 class="card-title text-lg font-bold leading-tight line-clamp-2" title={courseTitle}>
                {courseTitle}
            </h2>
        </a>
        
        <p class="text-sm text-[var(--color-text-muted)] line-clamp-2 mt-2 flex-grow">
            {descripcionCorta}
        </p>

        <!-- Botón para ver detalles del curso -->
        <div class="card-actions justify-end mt-4 pt-4 border-t border-base-200">
            <a href={`/cursos/${slugCurso}`} class="btn btn-outline h-10 min-h-[40px] hover:!bg-[var(--color-btn-hover)] hover:!border-[var(--color-btn-hover)] hover:!text-white rounded-xl transition-all duration-300">
                Ver Detalles
            </a>
        </div>
    </div>
</div>
