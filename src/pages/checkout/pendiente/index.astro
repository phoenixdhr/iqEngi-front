---
import LayoutSeo from '@layouts/LayoutSeo.astro';
---

<LayoutSeo
    tituloPagina="Pago Pendiente"
    description="Tu pago está siendo procesado"
    slug="checkout/pendiente"
    seoJsonLd={null}
>
    <div class="max-w-2xl mx-auto px-4 py-16 text-center">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-warning/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-[var(--color-warning)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>

        <h1 class="text-3xl font-extrabold text-base-content mb-4">
            Pago en Proceso
        </h1>

        <p class="text-lg text-base-content/70 mb-8">
            Tu pago está siendo procesado. Recibirás un email de confirmación cuando se complete.
            Esto puede tomar algunos minutos dependiendo del método de pago utilizado.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/cursos" class="btn btn-primary text-white">
                Explorar Cursos
            </a>
            <a href="/" class="btn btn-outline">
                Ir al Inicio
            </a>
        </div>
    </div>

    <!-- Script: Limpiar carrito cuando el pago está en proceso (ticket de efectivo, transferencia, etc.) -->
    <script>
        import { CARRITO_CURSOS, CART_CHANGE_EVENT } from '@const/const-string';
        localStorage.removeItem(CARRITO_CURSOS);
        window.dispatchEvent(new CustomEvent(CART_CHANGE_EVENT, { detail: [] }));
    </script>
</LayoutSeo>
