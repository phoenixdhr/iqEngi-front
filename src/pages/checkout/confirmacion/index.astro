---
import LayoutSeo from '@layouts/LayoutSeo.astro';
---

<LayoutSeo
    tituloPagina="Pago Exitoso"
    description="Tu pago ha sido procesado correctamente"
    slug="checkout/confirmacion"
    seoJsonLd={null}
>
    <div class="max-w-2xl mx-auto px-4 py-16 text-center">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-success/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
        </div>

        <h1 class="text-3xl font-extrabold text-base-content mb-4">
            ¡Pago Exitoso!
        </h1>

        <p class="text-lg text-base-content/70 mb-8">
            Tu compra ha sido procesada correctamente. Ya puedes acceder a tus cursos desde tu panel de estudiante.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/usuario/mis-cursos" class="btn btn-primary text-white">
                Ir a Mis Cursos
            </a>
            <a href="/cursos" class="btn btn-outline">
                Explorar Más Cursos
            </a>
        </div>
    </div>

    <!-- Script: Limpiar carrito al confirmar pago exitoso -->
    <script>
        import { CARRITO_CURSOS, CART_CHANGE_EVENT } from '@const/const-string';
        localStorage.removeItem(CARRITO_CURSOS);
        window.dispatchEvent(new CustomEvent(CART_CHANGE_EVENT, { detail: [] }));
    </script>
</LayoutSeo>
